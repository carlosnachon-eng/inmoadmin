# Supabase público: requerido por el cliente web.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase privilegiado: solo para rutas API del servidor.
SUPABASE_SERVICE_ROLE_KEY=

# URL base del ambiente actual.
# Local: http://localhost:3000
# Producción: https://app.emporioinmobiliario.com.mx
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ENV=

# Seguridad y demo de condominios. Nunca habilitar demo en producción.
INMOADMIN_DEMO=false
CONDOMINIOS_DEMO_CONFIRM=
CONDOMINIOS_DEMO_PASSWORD=
CONDOMINIOS_AUDIT_SALT=
# Mantener false hasta configurar una credencial Resend exclusiva del ambiente.
CONDOMINIOS_RECEIPT_SEND_ENABLED=false
CONDOMINIOS_RECEIPT_FROM=Emporio Inmobiliario <cobros@emporioinmobiliario.com.mx>
# Vacío por defecto; separar varios destinatarios autorizados con coma.
CONDOMINIOS_RECEIPT_BCC=

# Protección de endpoints ejecutados por Vercel Cron.
CRON_SECRET=

# Correo transaccional.
RESEND_API_KEY=

# Integraciones externas.
ANTHROPIC_API_KEY=
DIDIT_API_KEY=
EASYBROKER_API_KEY=
GOOGLE_SERVICE_ACCOUNT=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
RESPOND_IO_TOKEN=
