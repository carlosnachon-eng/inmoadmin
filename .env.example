# Supabase público: requerido por el cliente web.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase privilegiado: solo para rutas API del servidor.
SUPABASE_SERVICE_ROLE_KEY=

# URL base del ambiente actual.
# Local: http://localhost:3000
# Producción: https://app.emporioinmobiliario.com.mx
NEXT_PUBLIC_APP_URL=

# Protección de endpoints ejecutados por Vercel Cron.
CRON_SECRET=

# Correo transaccional.
RESEND_API_KEY=

# Integraciones externas.
ANTHROPIC_API_KEY=
DIDIT_API_KEY=
EASYBROKER_API_KEY=
GOOGLE_SERVICE_ACCOUNT=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
RESPOND_IO_TOKEN=

